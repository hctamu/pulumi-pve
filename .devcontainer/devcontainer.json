// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
{
	"name": "Pulumi dev",
	"build": {
		// Sets the run context to one level up instead of the .devcontainer folder.
		"context": "..",
		// Update the 'dockerFile' property if you aren't using the standard 'Dockerfile' filename.
		"dockerfile": "../Dockerfile"
	},
	"initializeCommand": "mkdir -p ~/.local/share/opencode ~/.ssh && touch ~/.auth_storage.json && touch ~/.secrets",
	"mounts": [
		"source=${localEnv:HOME}/.auth_storage.json,target=/home/vscode/.auth_storage.json,type=bind",
		"source=${localEnv:HOME}/.secrets,target=/home/vscode/.secrets,type=bind,readonly",
		"source=${localEnv:HOME}/.local/share/opencode,target=/home/vscode/.local/share/opencode,type=bind",
	],
	"remoteEnv": {
		"XDG_CACHE_HOME": "/home/vscode/.cache",
		"XDG_CONFIG_HOME": "/home/vscode/.config"
	},
	// For this to work the user needs to have a valid SSH key in their home directory called id_ed25519.pub
	"postStartCommand": "git config --global gpg.format ssh; git config --global user.signingkey /vscode/.ssh/id_ed25519.pub; git config --global commit.gpgsign true; git config --global core.excludesFile ~/.gitignore_global; touch ~/.gitignore_global",
	"runArgs": [
		"--name", "pulumi-pve",
		"-v", "${localEnv:HOME}/.ssh/id_ed25519.pub:/vscode/.ssh/id_ed25519.pub:Z"
		],
  "remoteUser": "vscode",
	"customizations": {
			"vscode": {
				"extensions": [
					"golang.go",
					"redhat.vscode-yaml",
					"hnw.vscode-auto-open-markdown-preview",
					"davidanson.vscode-markdownlint",
					"eamodio.gitlens",
					"stuart.unique-window-colors",
					"alexkrechik.cucumberautocomplete",
					"gitlab.gitlab-workflow",
					"jasonn-porch.gitlab-mr",
					"github.copilot",
					"ms-azuretools.vscode-docker",
					"github.vscode-github-actions",
					"pulumi.pulumi-vscode-tools",
          "emeraldwalk.runonsave",
          "anthropic.claude-code",
          "sst-dev.opencode"
				],
        "settings": {
          "emeraldwalk.runonsave": {
              "commands": [
                  {
                      "match": "\\.go$",
                      "cmd": "golines ${file} -w -m 120 -t 2"
                  }
              ]
          }
        }
			}
		}
}
