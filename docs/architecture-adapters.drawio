        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- VMAdapter                                              -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="vm" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;VMAdapter&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;- client : *ProxmoxAdapter&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;+ CreateVM(ctx, inputs) : error&lt;br/&gt;+ CloneVM(ctx, inputs) : error&lt;br/&gt;+ Get(ctx, vmID, node, userDisks) : (VMInputs, error)&lt;br/&gt;+ UpdateConfig(ctx, vmID, node, inputs, state) : error&lt;br/&gt;+ Delete(ctx, vmID, node) : error&lt;br/&gt;+ ApplyConfig(ctx, vmID, node, inputs, timeout) : error&lt;br/&gt;+ GetCurrentDisks(ctx, vmID, node) : (map, *EfiDisk, error)&lt;br/&gt;+ ResizeDisk(ctx, vmID, node, iface, size) : error&lt;br/&gt;+ RemoveDisk(ctx, vmID, node, iface) : error&lt;br/&gt;+ RemoveEfiDisk(ctx, vmID, node) : error&lt;br/&gt;- findVM(ctx, vmID, node) : (*api.VM, error)&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Courier New;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
