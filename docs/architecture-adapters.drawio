<mxfile host="app.diagrams.net" type="device">
  <diagram name="Adapters Package — UML Class Diagram" id="adapters-uml">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- ProxmoxAdapter                                         -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="pa" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;ProxmoxAdapter&lt;/b&gt;&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-top:2px;text-align:center;font-size:10px;&quot;&gt;&lt;i&gt;implements proxmox.Client&lt;/i&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;- once : sync.Once&lt;br/&gt;- initErr : error&lt;br/&gt;+ PVEConfig : *config.Config&lt;br/&gt;- client : *api.Client&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;+ Connect(ctx) : error&lt;br/&gt;+ Get(ctx, path) : ([]byte, error)&lt;br/&gt;+ Post(ctx, path, body) : ([]byte, error)&lt;br/&gt;+ Put(ctx, path, body) : ([]byte, error)&lt;br/&gt;+ Delete(ctx, path) : ([]byte, error)&lt;br/&gt;+ ResolveNode(ctx) : (string, error)&lt;br/&gt;+ NextVMID(ctx) : (int, error)&lt;br/&gt;+ Node(ctx, name) : (*api.Node, error)&lt;br/&gt;+ WaitForTask(ctx, task, timeout, interval) : error&lt;br/&gt;+ FindVirtualMachine(ctx, id) : (*api.VM, error)&lt;br/&gt;+ FindVirtualMachineOnNode(ctx, node, id) : (*api.VM, error)&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Courier New;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="460" height="380" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- PoolAdapter                                            -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="pool" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;&quot;&gt;&lt;b&gt;PoolAdapter&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;- proxmoxAdapter : *ProxmoxAdapter&lt;/p&gt;&lt;hr size=&quot;1&quot;/&gt;&lt;p style=&quot;margin:0px;margin-left:4px;&quot;&gt;+ Create(ctx, inputs) : error&lt;br/&gt;+ Get(ctx, name) : (*PoolOutputs, error)&lt;br/&gt;+ Update(ctx, name, inputs) : error&lt;br/&gt;+ Delete(ctx, name) : error&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;fontSize=11;fontFamily=Courier New;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="580" y="40" width="340" height="180" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- HAAdapter                                              -->
